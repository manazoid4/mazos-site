{
  "name": "mazos-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": "24.14.1",
    "npm": "11.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/serve-static.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "node --test tests/*.test.mjs",
    "test:links": "node --test tests/static-export.test.mjs",
    "smoke": "node scripts/smoke.mjs",
    "verify": "npm run typecheck && npm run build && npm test && npm run smoke"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
